{
  "manifest_version": 3,
  "name": "SquidJob Fleet Monitor",
  "version": "1.0.0",
  "description": "Lightweight status viewer for SquidJob Hub fleet",
  "permissions": ["storage", "alarms", "notifications"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
